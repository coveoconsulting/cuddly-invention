NODE_ENV="development"
HOST="0.0.0.0"
PORT="3000"
TRUST_PROXY="false"
REQUEST_BODY_LIMIT="1mb"
LOG_LEVEL="info"
APP_TIMEZONE="Africa/Casablanca"

# REQUIRED in production. Must be >= 32 characters (the server throws otherwise).
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="replace-with-a-long-random-secret-of-at-least-32-chars"

# REQUIRED in every environment. The app is Postgres-only.
# POSTGRES_URL and POSTGRES_PRISMA_URL are also accepted as fallbacks.
DATABASE_URL="postgres://user:password@host:5432/database"

# REQUIRED for the first production boot when the database is empty.
# Password must be >= 12 characters.
BOOTSTRAP_ADMIN_EMAIL="admin@your-company.com"
BOOTSTRAP_ADMIN_PASSWORD="replace-with-a-strong-password-min-12-chars"
BOOTSTRAP_ADMIN_NAME="Platform Admin"
BOOTSTRAP_COMPANY_NAME="Clerivo"
BOOTSTRAP_COMPANY_VERTICAL="Force commerciale terrain"
BOOTSTRAP_COMPANY_CURRENCY="MAD"
BOOTSTRAP_COMPANY_COUNTRY="Morocco"
BOOTSTRAP_DEFAULT_TERRITORY="Territoire principal"

# Optional AI assistant configuration. Without it the assistant uses a deterministic fallback.
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"

# WhatsApp Cloud API (Meta). Configurable via /whatsapp UI (admin/director),
# these vars are only used to seed a fresh deployment if you prefer env-based config.
# Webhook URL to declare in Meta:  https://<your-domain>/api/whatsapp/webhook
# Phone Number ID / Business Account ID come from Meta Business → WhatsApp → API Setup.
# WHATSAPP_PHONE_NUMBER_ID=""
# WHATSAPP_BUSINESS_ACCOUNT_ID=""
# WHATSAPP_ACCESS_TOKEN=""
# WHATSAPP_VERIFY_TOKEN=""
# WHATSAPP_APP_SECRET=""

# Vercel Blob — required for storing quote signatures and attachments out of the DB.
# Create the store from Vercel dashboard → Storage → Blob, then `vercel env pull`.
# Without this, signatures fall back to base64 in DB and attachment uploads are refused.
BLOB_READ_WRITE_TOKEN=""

# Vercel Cron secret. Must match Authorization: Bearer <CRON_SECRET> sent by Vercel.
# In dev (no Vercel) leave empty to allow manual hits to /api/cron/quote-reminders.
CRON_SECRET=""

# Public base URL used to build signing links shared with clients (e.g. https://crm.example.com).
# Falls back to VERCEL_URL automatically when deployed.
APP_PUBLIC_URL=""

# Resend (transactional email — already used for password reset; reused for quote send + reminders).
RESEND_API_KEY=""
RESEND_FROM_EMAIL="onboarding@resend.dev"

# Mapbox (carte des visites / tournées). Token PUBLIC (pk.*) - sûr de l'exposer côté client.
# Récupérez-le sur https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=""
