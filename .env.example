NODE_ENV="development"
HOST="0.0.0.0"
PORT="3000"
TRUST_PROXY="false"
REQUEST_BODY_LIMIT="1mb"
LOG_LEVEL="info"
APP_TIMEZONE="Africa/Casablanca"

# Required in production. Use a long random secret with at least 32 characters.
SESSION_SECRET="replace-with-a-long-random-secret"

# Required only for the first production boot when data/app-db.json does not exist.
BOOTSTRAP_ADMIN_EMAIL="admin@your-company.com"
BOOTSTRAP_ADMIN_PASSWORD="replace-with-a-strong-password"
BOOTSTRAP_ADMIN_NAME="Platform Admin"
BOOTSTRAP_COMPANY_NAME="Clerivo"
BOOTSTRAP_COMPANY_VERTICAL="Force commerciale terrain"
BOOTSTRAP_COMPANY_CURRENCY="MAD"
BOOTSTRAP_COMPANY_COUNTRY="Morocco"
BOOTSTRAP_DEFAULT_TERRITORY="Territoire principal"

# Optional AI assistant configuration.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
GEMINI_MODEL="gemini-2.5-flash"
